//HERC01N  JOB (ACCT),'NQUEENS',CLASS=A,MSGCLASS=Z,
//         MSGLEVEL=(1,1),REGION=8M,TIME=1440
//*
//* N-QUEENS SOLVER - IBM OS/360 COBOL UNDER MVT
//* READS BOARD SIZE (2-DIGIT) FROM SYSIN CARD
//*
//NQUEEN   EXEC COBUCG,
//         PARM.COB='FLAGW,LOAD,SUPMAP,SIZE=2048K,BUF=1024K,PMAP,XREF'
//COB.SYSPUNCH DD DUMMY
//COB.SYSIN DD *
000100* ============================================
000200* N-QUEENS SOLVER - ALL SOLUTIONS
000300* READS N (01-15) FROM SYSIN CARD IMAGE
000400* SOLVES VIA ITERATIVE BACKTRACKING
000500* FOUR-PASS APPROACH:
000600*   PASS 1 - COUNT ALL SOLUTIONS
000700*   PASS 2 - PRINT ALL BOARDS
000800*   PASS 3 - COUNT UNIQUE (MIRRORS REMOVED)
000900*   PASS 4 - PRINT UNIQUE BOARDS (NEW PAGE)
001000* ============================================
001100 IDENTIFICATION DIVISION.
001200 PROGRAM-ID. NQUEENS.
001300 AUTHOR. MOSHIX.
001400 ENVIRONMENT DIVISION.
001450 CONFIGURATION SECTION.
001460 SPECIAL-NAMES.
001470     C01 IS TOP-OF-PAGE.
001500 INPUT-OUTPUT SECTION.
001600 FILE-CONTROL.
001700     SELECT CARD-FILE ASSIGN TO UT-S-SYSIN.
001800     SELECT PRINT-FILE ASSIGN TO UT-S-SYSOUT.
001900 DATA DIVISION.
002000 FILE SECTION.
002100 FD  CARD-FILE
002200     LABEL RECORDS ARE OMITTED.
002300 01  CARD-RECORD.
002400     05  CARD-N                PIC 99.
002500     05  FILLER                PIC X(78).
002600 FD  PRINT-FILE
002700     LABEL RECORDS ARE OMITTED.
002800 01  PRINT-REC                PIC X(132).
002900 WORKING-STORAGE SECTION.
003000 01  N                         PIC 99.
003100 01  CURRENT-ROW               PIC 99.
003200 01  CHECK-ROW                 PIC 99.
003300 01  COL-DIFF                  PIC S99.
003400 01  ROW-DIFF                  PIC S99.
003500 01  VALID-FLAG                PIC 9.
003600 01  PRINT-ROW                 PIC 99.
003700 01  PRINT-COL                 PIC 99.
003800 01  QUEEN-TABLE.
003900     05  QUEEN-COL             PIC 99
004000         OCCURS 15 TIMES.
004100 01  SOL-COUNT                 PIC 9(10) VALUE 0.
004200 01  SOL-NUMBER                PIC 9(10) VALUE 0.
004300 01  RUN-MODE                  PIC 9.
004400     88  MODE-COUNT            VALUE 1.
004500     88  MODE-PRINT            VALUE 2.
004600     88  MODE-UCOUNT           VALUE 3.
004700     88  MODE-UPRINT           VALUE 4.
004800 01  BOARD-LINE.
004900     05  BOARD-CELL            PIC XX
005000         OCCURS 15 TIMES.
005100 01  HEADER-LINE.
005200     05  FILLER                PIC X(14)
005300         VALUE 'SOLUTION FOR '.
005400     05  HEADER-N              PIC Z9.
005500     05  FILLER                PIC X(9)
005600         VALUE ' QUEENS:'.
005700 01  COUNT-LINE.
005800     05  FILLER                PIC X(17)
005900         VALUE 'FOUND SOLUTIONS: '.
006000     05  COUNT-DISP            PIC Z(9)9.
006100 01  SOL-LABEL-LINE.
006200     05  FILLER                PIC X(10)
006300         VALUE 'SOLUTION #'.
006400     05  SOL-LABEL-NUM         PIC Z(9)9.
006500 01  MIRROR-COL                PIC 99.
006600 01  MIRROR-TABLE.
006700     05  MIRROR-Q-COL          PIC 99
006800         OCCURS 15 TIMES.
006900 01  COMPARE-FLAG              PIC 9.
007000 01  COMPARE-IDX               PIC 99.
007100 01  UNIQUE-COUNT              PIC 9(10) VALUE 0.
007200 01  UNIQUE-NUMBER             PIC 9(10) VALUE 0.
007300 01  UNIQUE-COUNT-LINE.
007400     05  FILLER                PIC X(20)
007500         VALUE 'UNIQUE SOLUTIONS:   '.
007600     05  UNIQUE-DISP           PIC Z(9)9.
007700 01  UNIQUE-HEADER.
007800     05  FILLER                PIC X(20)
007900         VALUE 'UNIQUE SOLUTION #   '.
008000     05  UNIQUE-LABEL-NUM      PIC Z(9)9.
008100 PROCEDURE DIVISION.
008200* ----------------------------------------
008300* READ THE BOARD SIZE FROM INPUT CARD
008400* ----------------------------------------
008500 MAIN-LOGIC.
008600     OPEN INPUT CARD-FILE.
008700     OPEN OUTPUT PRINT-FILE.
008800     READ CARD-FILE AT END
008900         DISPLAY 'NO INPUT CARD FOUND'
009000         STOP RUN.
009100     MOVE CARD-N TO N.
009200     CLOSE CARD-FILE.
009300     IF N < 1
009400         DISPLAY 'N MUST BE BETWEEN 1 AND 15'
009500         STOP RUN.
009600     IF N > 15
009700         DISPLAY 'N MUST BE BETWEEN 1 AND 15'
009800         STOP RUN.
009900     MOVE SPACES TO PRINT-REC.
010000     WRITE PRINT-REC AFTER ADVANCING TOP-OF-PAGE.
010100     MOVE N TO HEADER-N.
010200     MOVE HEADER-LINE TO PRINT-REC.
010300     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
010400     MOVE SPACES TO PRINT-REC.
010500     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
010600* ----------------------------------------
010700* PASS 1 - COUNT ALL SOLUTIONS
010800* ----------------------------------------
010900     MOVE 1 TO RUN-MODE.
011000     MOVE 0 TO SOL-COUNT.
011100     PERFORM RUN-SOLVER THRU SOLVER-EXIT.
011200     IF SOL-COUNT = 0
011300         MOVE 'NO SOLUTION EXISTS' TO PRINT-REC
011400         WRITE PRINT-REC AFTER ADVANCING 1 LINES
011500         CLOSE PRINT-FILE
011600         STOP RUN.
011700     MOVE SOL-COUNT TO COUNT-DISP.
011800     MOVE COUNT-LINE TO PRINT-REC.
011900     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
012000     MOVE SPACES TO PRINT-REC.
012100     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
012200* ----------------------------------------
012300* PASS 2 - PRINT ALL SOLUTION BOARDS
012400* ----------------------------------------
012500     MOVE 2 TO RUN-MODE.
012600     MOVE 0 TO SOL-NUMBER.
012700     PERFORM RUN-SOLVER THRU SOLVER-EXIT.
012800* ----------------------------------------
012900* PASS 3 - COUNT UNIQUE SOLUTIONS
013000* ----------------------------------------
013100     MOVE 3 TO RUN-MODE.
013200     MOVE 0 TO UNIQUE-COUNT.
013300     PERFORM RUN-SOLVER THRU SOLVER-EXIT.
013400     MOVE UNIQUE-COUNT TO UNIQUE-DISP.
013500* ----------------------------------------
013600* PRINT UNIQUE COUNT AND START NEW PAGE
013700* ----------------------------------------
013800     MOVE '================================' TO PRINT-REC.
013900     WRITE PRINT-REC AFTER ADVANCING TOP-OF-PAGE.
014000     MOVE 'UNIQUE SOLUTIONS (MIRRORS REMOVED):' TO
014100         PRINT-REC.
014200     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
014300     MOVE UNIQUE-COUNT-LINE TO PRINT-REC.
014400     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
014500     MOVE '================================' TO PRINT-REC.
014600     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
014700     MOVE SPACES TO PRINT-REC.
014800     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
014900* ----------------------------------------
015000* PASS 4 - PRINT UNIQUE SOLUTION BOARDS
015100* ----------------------------------------
015200     MOVE 4 TO RUN-MODE.
015300     MOVE 0 TO UNIQUE-NUMBER.
015400     PERFORM RUN-SOLVER THRU SOLVER-EXIT.
015500     MOVE SPACES TO PRINT-REC.
015600     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
015700     CLOSE PRINT-FILE.
015800     STOP RUN.
015900* ----------------------------------------
016000* BACKTRACKING SOLVER
016100* REUSABLE FOR ALL FOUR PASSES
016200* ----------------------------------------
016300 RUN-SOLVER.
016400     MOVE 1 TO CURRENT-ROW.
016500     MOVE 0 TO QUEEN-COL (1).
016600 TRY-NEXT.
016700     ADD 1 TO QUEEN-COL (CURRENT-ROW).
016800     IF QUEEN-COL (CURRENT-ROW) > N
016900         GO TO BACKTRACK.
017000     PERFORM CHECK-VALID THRU CHECK-DONE.
017100     IF VALID-FLAG = 0
017200         GO TO TRY-NEXT.
017300     IF CURRENT-ROW = N
017400         GO TO FOUND-SOLUTION.
017500     ADD 1 TO CURRENT-ROW.
017600     MOVE 0 TO QUEEN-COL (CURRENT-ROW).
017700     GO TO TRY-NEXT.
017800 BACKTRACK.
017900     SUBTRACT 1 FROM CURRENT-ROW.
018000     IF CURRENT-ROW < 1
018100         GO TO SOLVER-EXIT.
018200     GO TO TRY-NEXT.
018300* ----------------------------------------
018400* SOLUTION FOUND - ACT BASED ON MODE
018500* ----------------------------------------
018600 FOUND-SOLUTION.
018700     IF MODE-COUNT
018800         ADD 1 TO SOL-COUNT
018900         GO TO TRY-NEXT.
019000     IF MODE-PRINT
019100         ADD 1 TO SOL-NUMBER
019200         GO TO PRINT-BOARD.
019300     PERFORM COMPUTE-MIRROR THRU COMPARE-DONE.
019400     IF COMPARE-FLAG = 2
019500         GO TO TRY-NEXT.
019600     IF MODE-UCOUNT
019700         ADD 1 TO UNIQUE-COUNT
019800         GO TO TRY-NEXT.
019900     ADD 1 TO UNIQUE-NUMBER.
020000     GO TO PRINT-UNIQUE.
020100* ----------------------------------------
020200* CHECK IF QUEEN PLACEMENT IS VALID
020300* ----------------------------------------
020400 CHECK-VALID.
020500     MOVE 1 TO VALID-FLAG.
020600     MOVE 1 TO CHECK-ROW.
020700 CHECK-LOOP.
020800     IF CHECK-ROW NOT LESS THAN CURRENT-ROW
020900         GO TO CHECK-DONE.
021000     IF QUEEN-COL (CHECK-ROW) =
021100         QUEEN-COL (CURRENT-ROW)
021200         MOVE 0 TO VALID-FLAG
021300         GO TO CHECK-DONE.
021400     COMPUTE COL-DIFF =
021500         QUEEN-COL (CHECK-ROW) -
021600         QUEEN-COL (CURRENT-ROW).
021700     IF COL-DIFF < 0
021800         MULTIPLY -1 BY COL-DIFF.
021900     COMPUTE ROW-DIFF =
022000         CHECK-ROW - CURRENT-ROW.
022100     IF ROW-DIFF < 0
022200         MULTIPLY -1 BY ROW-DIFF.
022300     IF COL-DIFF = ROW-DIFF
022400         MOVE 0 TO VALID-FLAG
022500         GO TO CHECK-DONE.
022600     ADD 1 TO CHECK-ROW.
022700     GO TO CHECK-LOOP.
022800 CHECK-DONE.
022900     EXIT.
023000* ----------------------------------------
023100* COMPUTE MIRROR AND COMPARE WITH ORIGINAL
023200* COMPARE-FLAG: 0=EQUAL 1=ORIG<MIR 2=ORIG>MIR
023300* ----------------------------------------
023400 COMPUTE-MIRROR.
023500     MOVE 1 TO COMPARE-IDX.
023600 COMPUTE-MIRROR-LOOP.
023700     IF COMPARE-IDX > N
023800         GO TO COMPARE-ARRAYS.
023900     COMPUTE MIRROR-Q-COL (COMPARE-IDX) =
024000         N + 1 - QUEEN-COL (COMPARE-IDX).
024100     ADD 1 TO COMPARE-IDX.
024200     GO TO COMPUTE-MIRROR-LOOP.
024300 COMPARE-ARRAYS.
024400     MOVE 0 TO COMPARE-FLAG.
024500     MOVE 1 TO COMPARE-IDX.
024600 COMPARE-LOOP.
024700     IF COMPARE-IDX > N
024800         GO TO COMPARE-DONE.
024900     IF QUEEN-COL (COMPARE-IDX) <
025000         MIRROR-Q-COL (COMPARE-IDX)
025100         MOVE 1 TO COMPARE-FLAG
025200         GO TO COMPARE-DONE.
025300     IF QUEEN-COL (COMPARE-IDX) >
025400         MIRROR-Q-COL (COMPARE-IDX)
025500         MOVE 2 TO COMPARE-FLAG
025600         GO TO COMPARE-DONE.
025700     ADD 1 TO COMPARE-IDX.
025800     GO TO COMPARE-LOOP.
025900 COMPARE-DONE.
026000     EXIT.
026100* ----------------------------------------
026200* PRINT BOARD - NORMAL ORIENTATION (PASS 2)
026300* Q = QUEEN    . = EMPTY SQUARE
026400* ----------------------------------------
026500 PRINT-BOARD.
026600     MOVE SOL-NUMBER TO SOL-LABEL-NUM.
026700     MOVE SOL-LABEL-LINE TO PRINT-REC.
026800     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
026900     MOVE 1 TO PRINT-ROW.
027000 PRINT-ROW-LOOP.
027100     IF PRINT-ROW > N
027200         GO TO PRINT-BOARD-DONE.
027300     MOVE SPACES TO BOARD-LINE.
027400     MOVE 1 TO PRINT-COL.
027500 PRINT-COL-LOOP.
027600     IF PRINT-COL > N
027700         GO TO DISPLAY-ROW.
027800     IF QUEEN-COL (PRINT-ROW) = PRINT-COL
027900         MOVE 'Q ' TO BOARD-CELL (PRINT-COL)
028000         GO TO NEXT-COL.
028100     MOVE '. ' TO BOARD-CELL (PRINT-COL).
028200 NEXT-COL.
028300     ADD 1 TO PRINT-COL.
028400     GO TO PRINT-COL-LOOP.
028500 DISPLAY-ROW.
028600     MOVE BOARD-LINE TO PRINT-REC.
028700     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
028800     ADD 1 TO PRINT-ROW.
028900     GO TO PRINT-ROW-LOOP.
029000 PRINT-BOARD-DONE.
029100     MOVE SPACES TO PRINT-REC.
029200     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
029300     GO TO TRY-NEXT.
029400* ----------------------------------------
029500* PRINT UNIQUE BOARD (PASS 4)
029600* ----------------------------------------
029700 PRINT-UNIQUE.
029800     MOVE UNIQUE-NUMBER TO UNIQUE-LABEL-NUM.
029900     MOVE UNIQUE-HEADER TO PRINT-REC.
030000     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
030100     MOVE 1 TO PRINT-ROW.
030200 UNIQUE-ROW-LOOP.
030300     IF PRINT-ROW > N
030400         GO TO UNIQUE-BOARD-DONE.
030500     MOVE SPACES TO BOARD-LINE.
030600     MOVE 1 TO PRINT-COL.
030700 UNIQUE-COL-LOOP.
030800     IF PRINT-COL > N
030900         GO TO UNIQUE-DISPLAY-ROW.
031000     IF QUEEN-COL (PRINT-ROW) = PRINT-COL
031100         MOVE 'Q ' TO BOARD-CELL (PRINT-COL)
031200         GO TO UNIQUE-NEXT-COL.
031300     MOVE '. ' TO BOARD-CELL (PRINT-COL).
031400 UNIQUE-NEXT-COL.
031500     ADD 1 TO PRINT-COL.
031600     GO TO UNIQUE-COL-LOOP.
031700 UNIQUE-DISPLAY-ROW.
031800     MOVE BOARD-LINE TO PRINT-REC.
031900     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
032000     ADD 1 TO PRINT-ROW.
032100     GO TO UNIQUE-ROW-LOOP.
032200 UNIQUE-BOARD-DONE.
032300     MOVE SPACES TO PRINT-REC.
032400     WRITE PRINT-REC AFTER ADVANCING 1 LINES.
032500     GO TO TRY-NEXT.
032600 SOLVER-EXIT.
032700     EXIT.
