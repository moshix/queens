//HERC01N  JOB (ACCT),'NQUEENS',CLASS=A,MSGCLASS=A,
//         MSGLEVEL=(1,1)
//*
//* N-QUEENS SOLVER - IBM OS/360 COBOL UNDER MVT
//* READS BOARD SIZE (2-DIGIT) FROM SYSIN CARD
//* FINDS FIRST SOLUTION VIA BACKTRACKING
//*
//STEP1   EXEC COBUCLG
//COB.SYSIN DD *
000100* ============================================
000200* N-QUEENS SOLVER
000300* READS N (01-20) FROM SYSIN CARD IMAGE
000400* SOLVES VIA ITERATIVE BACKTRACKING
000500* DISPLAYS SOLUTION AS A CHESSBOARD
000600* ============================================
000700 IDENTIFICATION DIVISION.
000800 PROGRAM-ID. NQUEENS.
000900 AUTHOR. MOSHIX.
001000 ENVIRONMENT DIVISION.
001100 INPUT-OUTPUT SECTION.
001200 FILE-CONTROL.
001300     SELECT CARD-FILE ASSIGN TO UT-S-SYSIN.
001400 DATA DIVISION.
001500 FILE SECTION.
001600 FD  CARD-FILE
001700     LABEL RECORDS ARE OMITTED.
001800 01  CARD-RECORD.
001900     05  CARD-N                PIC 99.
002000     05  FILLER                PIC X(78).
002100 WORKING-STORAGE SECTION.
002200 01  N                         PIC 99.
002300 01  CURRENT-ROW               PIC 99.
002400 01  CHECK-ROW                 PIC 99.
002500 01  COL-DIFF                  PIC S99.
002600 01  ROW-DIFF                  PIC S99.
002700 01  VALID-FLAG                PIC 9.
002800 01  PRINT-ROW                 PIC 99.
002900 01  PRINT-COL                 PIC 99.
003000 01  QUEEN-TABLE.
003100     05  QUEEN-COL             PIC 99
003200         OCCURS 20 TIMES.
003300 01  BOARD-LINE.
003400     05  BOARD-CELL            PIC XX
003500         OCCURS 20 TIMES.
003600 01  HEADER-LINE.
003700     05  FILLER                PIC X(14)
003800         VALUE 'SOLUTION FOR '.
003900     05  HEADER-N              PIC Z9.
004000     05  FILLER                PIC X(9)
004100         VALUE ' QUEENS:'.
004200 PROCEDURE DIVISION.
004300* ----------------------------------------
004400* READ THE BOARD SIZE FROM INPUT CARD
004500* ----------------------------------------
004600 MAIN-LOGIC.
004700     OPEN INPUT CARD-FILE.
004800     READ CARD-FILE AT END
004900         DISPLAY 'NO INPUT CARD FOUND'
005000         STOP RUN.
005100     MOVE CARD-N TO N.
005200     CLOSE CARD-FILE.
005300     IF N < 1
005400         DISPLAY 'N MUST BE BETWEEN 1 AND 20'
005500         STOP RUN.
005600     IF N > 20
005700         DISPLAY 'N MUST BE BETWEEN 1 AND 20'
005800         STOP RUN.
005900     DISPLAY ' '.
006000     MOVE N TO HEADER-N.
006100     DISPLAY HEADER-LINE.
006200     DISPLAY ' '.
006300* ----------------------------------------
006400* INITIALIZE AND BEGIN BACKTRACKING
006500* ----------------------------------------
006600     MOVE 1 TO CURRENT-ROW.
006700     MOVE 0 TO QUEEN-COL (1).
006800 TRY-NEXT.
006900     ADD 1 TO QUEEN-COL (CURRENT-ROW).
007000     IF QUEEN-COL (CURRENT-ROW) > N
007100         GO TO BACKTRACK.
007200     PERFORM CHECK-VALID THRU CHECK-DONE.
007300     IF VALID-FLAG = 0
007400         GO TO TRY-NEXT.
007500     IF CURRENT-ROW = N
007600         GO TO PRINT-BOARD.
007700     ADD 1 TO CURRENT-ROW.
007800     MOVE 0 TO QUEEN-COL (CURRENT-ROW).
007900     GO TO TRY-NEXT.
008000 BACKTRACK.
008100     SUBTRACT 1 FROM CURRENT-ROW.
008200     IF CURRENT-ROW < 1
008300         DISPLAY 'NO SOLUTION EXISTS'
008400         STOP RUN.
008500     GO TO TRY-NEXT.
008600* ----------------------------------------
008700* CHECK IF QUEEN PLACEMENT IS VALID
008800* TESTS COLUMN AND DIAGONAL CONFLICTS
008900* AGAINST ALL PREVIOUSLY PLACED QUEENS
009000* ----------------------------------------
009100 CHECK-VALID.
009200     MOVE 1 TO VALID-FLAG.
009300     MOVE 1 TO CHECK-ROW.
009400 CHECK-LOOP.
009500     IF CHECK-ROW NOT LESS THAN CURRENT-ROW
009600         GO TO CHECK-DONE.
009700     IF QUEEN-COL (CHECK-ROW) =
009800         QUEEN-COL (CURRENT-ROW)
009900         MOVE 0 TO VALID-FLAG
010000         GO TO CHECK-DONE.
010100     COMPUTE COL-DIFF =
010200         QUEEN-COL (CHECK-ROW) -
010300         QUEEN-COL (CURRENT-ROW).
010400     IF COL-DIFF < 0
010500         MULTIPLY -1 BY COL-DIFF.
010600     COMPUTE ROW-DIFF =
010700         CHECK-ROW - CURRENT-ROW.
010800     IF ROW-DIFF < 0
010900         MULTIPLY -1 BY ROW-DIFF.
011000     IF COL-DIFF = ROW-DIFF
011100         MOVE 0 TO VALID-FLAG
011200         GO TO CHECK-DONE.
011300     ADD 1 TO CHECK-ROW.
011400     GO TO CHECK-LOOP.
011500 CHECK-DONE.
011600     EXIT.
011700* ----------------------------------------
011800* DISPLAY THE CHESSBOARD SOLUTION
011900* Q = QUEEN    . = EMPTY SQUARE
012000* ----------------------------------------
012100 PRINT-BOARD.
012200     MOVE 1 TO PRINT-ROW.
012300 PRINT-ROW-LOOP.
012400     IF PRINT-ROW > N
012500         GO TO PRINT-DONE.
012600     MOVE SPACES TO BOARD-LINE.
012700     MOVE 1 TO PRINT-COL.
012800 PRINT-COL-LOOP.
012900     IF PRINT-COL > N
013000         GO TO DISPLAY-ROW.
013100     IF QUEEN-COL (PRINT-ROW) = PRINT-COL
013200         MOVE 'Q ' TO BOARD-CELL (PRINT-COL)
013300         GO TO NEXT-COL.
013400     MOVE '. ' TO BOARD-CELL (PRINT-COL).
013500 NEXT-COL.
013600     ADD 1 TO PRINT-COL.
013700     GO TO PRINT-COL-LOOP.
013800 DISPLAY-ROW.
013900     DISPLAY BOARD-LINE.
014000     ADD 1 TO PRINT-ROW.
014100     GO TO PRINT-ROW-LOOP.
014200 PRINT-DONE.
014300     DISPLAY ' '.
014400     STOP RUN.
